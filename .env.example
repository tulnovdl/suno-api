# For more information, please see the README.md
SUNO_COOKIE=
TWOCAPTCHA_KEY= # Obtain from 2captcha.com
BROWSER=chromium # `chromium` or `firefox`, although `chromium` is highly recommended
BROWSER_GHOST_CURSOR=false
BROWSER_LOCALE=en
BROWSER_HEADLESS=true

# Comma-separated cookie names to filter out before Playwright addCookies.
# OptanonConsent ships with unencoded characters that Chromium rejects.
SUNO_COOKIE_BLOCKLIST=OptanonConsent
# Optional selector overrides if Suno tweaks the Create UI between releases.
SUNO_LYRICS_TEXTAREA_SELECTOR=
SUNO_CREATE_BUTTON_SELECTOR=
SUNO_SELECTOR_TIMEOUT_MS=60000
SUNO_DEFAULT_MODEL=chirp-fenix
SUNO_SKIP_CAPTCHA=false
SUNO_CAPTCHA_TIMEOUT_MS=240000
